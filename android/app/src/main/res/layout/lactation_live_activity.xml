<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/lactation_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/lactation_notification_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lactation_side"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/lactation_notification_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <Chronometer
        android:id="@+id/lactation_chronometer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:format="%s"
        android:paddingStart="8dp"
        android:textColor="@color/lactation_notification_primary"
        android:textSize="20sp"
        android:textStyle="bold" />
</LinearLayout>
